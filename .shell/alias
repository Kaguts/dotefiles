# Alias Docker
alias dstopa="docker stop \$(docker ps -a -q)"
alias dstatus='docker ps --format "table{{.ID}}\t{{.Image}}\t{{.RunningFor}}\t{{.Status}}\t{{.Ports}}\t{{.Names}}"'
alias dstarta="docker start \$(docker ps -a -q)"               
alias drm="docker rm \$(docker ps -a -q)"                     
alias dcleanc="docker rm \$(docker ps -f status=exited -q)"  
alias dcleani="docker rmi \$(docker images -f dangling=true -q)" 
alias dlogs="docker logs -f"                                   
alias dexec="docker exec -it"                                 
alias dbuild="docker build -t"                               
alias dip="docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'" 

# Alias Docker Compose (plugin v2 : "docker compose", sans tiret)
alias dcup="docker compose up -d"
alias dcdown="docker compose down"
alias dcrestart="docker compose restart"
alias dclogs="docker compose logs -f"
alias dcrebuild="docker compose up -d --build"
alias dcls="docker compose ps"

