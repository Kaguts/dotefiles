#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@#
#            Custom Functions            #
#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@#

# Recherche rapide dans l'historique
h() {
    history | grep "$1"
}

# Aller à un répertoire spécifique
cdd() {
    cd "$1" || echo "Le répertoire n'existe pas."
}

# Extraire automatiquement les fichiers
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"    ;;
            *.tar.gz)    tar xzf "$1"    ;;
            *.bz2)       bunzip2 "$1"    ;;
            *.rar)       unrar x "$1"    ;;
            *.gz)        gunzip "$1"     ;;
            *.tar)       tar xvf "$1"    ;;
            *.tbz2)      tar xjf "$1"    ;;
            *.tgz)       tar xzf "$1"    ;;
            *.zip)       unzip "$1"      ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1"       ;;
            *)           echo "Impossible d'extraire '$1'" ;;
        esac
    else
        echo "'$1' n'est pas un fichier valide"
    fi
}

# Rechercher un fichier par nom
ff() {
    find . -name "$1"
}

# Recherche d'un contenu dans les fichiers
fstr() {
    grep -rnw . -e "$1"
}

# Créer un répertoire et entrer dedans
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Remonter les processus les plus gourmands en mémoire
topmem() {
    ps aux --sort=-%mem | head -n 10
}

# Remonter les processus les plus gourmands en CPU
topcpu() {
    ps aux --sort=-%cpu | head -n 10
}

# Obtenir l'adresse IP locale
myip() {
    hostname -I | awk '{print $1}'
}
