#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@#
#       Outils CLI modernes              #
#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@#

# Sur Debian, bat/fd sont installés sous batcat/fdfind pour éviter
# un conflit de nom avec des paquets existants.
command -v bat >/dev/null || alias bat='batcat'
command -v fd >/dev/null || alias fd='fdfind'

alias cat='bat --paging=never'
alias top='btop'


# Alias des serveurs pour une connexion rapide (fichier local, non versionné)
[ -f ~/.shell/alias_srv ] && source ~/.shell/alias_srv

# Alias du man
alias man_alias="~/.shell/man_alias_all.sh"
alias adocker="~/.shell/man_alias_docker.sh"
alias asys="~/.shell/man_alias_sys.sh"
alias agit="~/.shell/man_alias_git.sh"
alias asysf="~/.shell/man_alias_sys_a.sh"

